{
  "name": "fluppy-monorepo",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "app",
    "packages/*"
  ],
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "scripts": {
    "build:core": "pnpm --filter @fluppy/core build",
    "build:app": "pnpm --filter frontend build",
    "build": "pnpm build:core && pnpm build:browser && pnpm build:react && pnpm build:app",
    "typecheck": "pnpm --filter @fluppy/core typecheck && pnpm --filter @fluppy/browser typecheck && pnpm --filter @fluppy/react typecheck",
    "test": "pnpm --filter @fluppy/core test",
    "build:browser": "pnpm --filter @fluppy/browser build",
    "build:react": "pnpm --filter @fluppy/react build",
    "typecheck:core": "pnpm --filter @fluppy/core typecheck",
    "typecheck:browser": "pnpm --filter @fluppy/browser typecheck"
  },
  "packageManager": "pnpm@10.28.0"
}
