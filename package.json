{
  "name": "flupy-monorepo",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "app",
    "packages/*"
  ],
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "scripts": {
    "build:core": "pnpm --filter @flupy/core build",
    "build:app": "pnpm --filter frontend build",
    "build": "pnpm build:core && pnpm build:browser && pnpm build:react && pnpm build:app",
    "typecheck": "pnpm --filter @flupy/core typecheck && pnpm --filter @flupy/browser typecheck && pnpm --filter @flupy/react typecheck",
    "test": "pnpm --filter @flupy/core test",
    "build:browser": "pnpm --filter @flupy/browser build",
    "build:react": "pnpm --filter @flupy/react build",
    "typecheck:core": "pnpm --filter @flupy/core typecheck",
    "typecheck:browser": "pnpm --filter @flupy/browser typecheck"
  },
  "packageManager": "pnpm@10.28.0"
}
