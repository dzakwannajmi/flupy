{
  "name": "@fluppy/browser",
  "version": "0.1.0",
  "private": true,
  "description": "Fluppy ZK Payment Protocol browser SDK",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fluppy/core": "workspace:*"
  },
  "peerDependencies": {
    "@stellar/freighter-api": ">=4.0.0",
    "@stellar/stellar-sdk": ">=12.0.0",
    "circomlibjs": ">=0.1.0",
    "snarkjs": ">=0.7.0"
  },
  "devDependencies": {
    "@stellar/freighter-api": "^4.0.0",
    "@stellar/stellar-sdk": "^13.0.0",
    "circomlibjs": "^0.1.0",
    "snarkjs": "^0.7.4",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "sideEffects": false
}
